# Telegram Bot Token (取自 @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Finnhub API Key (https://finnhub.io - 免費方案)
FINNHUB_API_KEY=your_finnhub_api_key_here

# NewsAPI Key (https://newsapi.org - 免費方案，每天 100 次)
NEWSAPI_KEY=your_newsapi_key_here

# GPT 模型 (gpt-4o-mini 較省錢，gpt-4o 品質更好)
GPT_MODEL=gpt-4o-mini

# 排程時間 (UTC)
# 盤前摘要：13:00 UTC = 台灣 21:00 = 美東 09:00
PREMARKET_HOUR_UTC=13
PREMARKET_MINUTE_UTC=0

# 盤後摘要：22:00 UTC = 台灣 06:00 = 美東 18:00
AFTERHOURS_HOUR_UTC=22
AFTERHOURS_MINUTE_UTC=0

# 新聞自動偵測間隔（分鐘）
NEWS_CHECK_INTERVAL=60
